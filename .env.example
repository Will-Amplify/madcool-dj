MUSIC_ROOT=/home/madcoolseed/Music
DJ_TOKEN=change-me-for-tailscale
# Non-loopback DJ_HOST requires a non-empty DJ_TOKEN (control refuses to start otherwise).
DJ_HOST=127.0.0.1
DJ_PORT=8787
# shared = PipeWire Default Sink (coexist with other clients / Roon System Output)
# exclusive = hold DAC; auto-release on Roon play for Tom - AES ALSA
DJ_AUDIO_MODE=shared
ROON_HOST=100.109.124.125
ROON_PORT=9330
ROON_PAIR_TIMEOUT_MS=10000
ACOUSTID_API_KEY=
MINIMAX_API_KEY=
# Or point at a key file (default: ~/MiniMax API.txt)
# MINIMAX_API_KEY_FILE=/home/madcoolseed/MiniMax API.txt
MINIMAX_API_BASE=https://api.minimax.io
ENGINE_SOCK=${XDG_RUNTIME_DIR}/madcool-dj.sock
